# ============================================================
# INCORED ERP - Variables de Entorno
# Copiar este archivo a .env y completar los valores reales
# NUNCA commitear el archivo .env al repositorio
# ============================================================

# ----- BASE DE DATOS -----
DATABASE_URL=postgresql://user:password@host:5432/incored_erp
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
DATABASE_SSL=true

# ----- SERVIDOR -----
NODE_ENV=production
PORT=5000
API_URL=https://api.incored.com.mx
FRONTEND_URL=https://erp.incored.com.mx

# ----- JWT -----
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-key-minimum-64-chars-long-change-this-immediately
JWT_EXPIRY=24h
REFRESH_TOKEN_SECRET=another-super-secret-key-different-from-jwt-secret
REFRESH_TOKEN_EXPIRY=7d

# ----- EMAIL (GoDaddy SMTP) -----
SMTP_HOST=smtpout.secureserver.net
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=operaciones@incored.com.mx
SMTP_PASS=your-godaddy-smtp-password
SMTP_FROM=operaciones@incored.com.mx
SMTP_FROM_NAME=IncorERP Sistema

# ----- AWS S3 -----
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=us-east-1
AWS_S3_BUCKET=incored-erp-files
AWS_S3_PRESIGNED_EXPIRY=3600

# ----- SENTRY (Error Tracking) -----
SENTRY_DSN=https://xxxxxxxxxxxxxxxx@oxxxxxxxxxx.ingest.sentry.io/xxxxxxx

# ----- ENCRIPTACIÓN -----
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-32-byte-hex-encryption-key-for-aes256

# ----- ADMIN INICIAL -----
ADMIN_EMAIL=admin@incored.com.mx
ADMIN_PASSWORD=ChangeThisImmediately123\!

# ----- RATE LIMITING -----
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
LOGIN_RATE_LIMIT_MAX=5

# ----- 2FA -----
TWO_FA_ISSUER=IncorERP
TWO_FA_WINDOW=1

# ----- LOGGING -----
LOG_LEVEL=info
LOG_FILE=logs/app.log

# ----- DOMINIOS PERMITIDOS (emails corporativos) -----
ALLOWED_EMAIL_DOMAINS=incored.com.mx,zhada.mx,mika.mx,zhada.com.mx
